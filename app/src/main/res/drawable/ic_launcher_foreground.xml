<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — 108 × 108 dp, safe zone: inner 72 dp (18–90).
  Concept: stylised exit door with a bold amber arrow exiting right.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Door body (white, arch top) ─────────────────────────────────── -->
    <!-- Outer arch: from (26,46) curving up to peak (45,24), down to (64,46),
         then rectangle body to y=88. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,46 Q26,24 45,24 Q64,24 64,46 L64,88 L26,88 Z" />

    <!-- ── Door opening (background colour — creates hollow effect) ─────── -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M33,46 Q33,31 45,31 Q57,31 57,46 L57,88 L33,88 Z" />

    <!-- ── Door handle (amber circle) ──────────────────────────────────── -->
    <!-- Circle centred at (53, 64), radius 3.5 -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M49.5,64 A3.5,3.5 0 1,0 56.5,64 A3.5,3.5 0 1,0 49.5,64 Z" />

    <!-- ── Exit arrow (amber, pointing right) ──────────────────────────── -->
    <!-- Shaft: x 62–84, y 50–58 -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M62,50 L82,50 L82,58 L62,58 Z" />
    <!-- Arrowhead triangle: tip at (92,54) -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M79,43 L92,54 L79,65 Z" />

    <!-- ── Checklist dots (white, lower right — "items to remember") ───── -->
    <path
        android:fillColor="#FFFFFF"
        android:alpha="0.75"
        android:pathData="M68,72 L88,72 L88,75 L68,75 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:alpha="0.75"
        android:pathData="M68,79 L83,79 L83,82 L68,82 Z" />
    <path
        android:fillColor="#FFC107"
        android:pathData="M64,72 A2,2 0 1,0 68,72 A2,2 0 1,0 64,72 Z" />
    <path
        android:fillColor="#FFC107"
        android:pathData="M64,79 A2,2 0 1,0 68,79 A2,2 0 1,0 64,79 Z" />

</vector>
